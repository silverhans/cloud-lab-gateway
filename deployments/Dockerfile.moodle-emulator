# syntax=docker/dockerfile:1.7

FROM golang:1.25-alpine AS build
WORKDIR /src
COPY go.mod go.sum ./
RUN go mod download
COPY . .
RUN CGO_ENABLED=0 go build -trimpath -ldflags='-s -w' -o /out/moodle-emulator ./cmd/moodle-emulator

FROM gcr.io/distroless/static-debian12:nonroot
COPY --from=build --chown=nonroot:nonroot /out/moodle-emulator /moodle-emulator
USER nonroot:nonroot
EXPOSE 9000
ENTRYPOINT ["/moodle-emulator"]
