# =============================================================================
# Cloud Lab Gateway — environment configuration
# =============================================================================
# Copy to .env and fill in. NEVER commit .env. See docs/SECURITY.md for the
# secret hierarchy (KEK > DEK > payload).

# ─── HTTP ────────────────────────────────────────────────────────────────────
HTTP_PORT=8080
CLG_BIND_ADDR=0.0.0.0:8080
LOG_LEVEL=info                  # debug | info | warn | error

# ─── Postgres ────────────────────────────────────────────────────────────────
POSTGRES_PASSWORD=clg
PG_DSN=postgres://clg:clg@postgres:5432/clg?sslmode=disable

# ─── Redis ───────────────────────────────────────────────────────────────────
REDIS_ADDR=redis:6379

# ─── Crypto (envelope encryption) ────────────────────────────────────────────
# Generate: openssl rand -base64 32
# Rotate periodically; old KEK versions must remain available until DEKs migrated.
CLG_KEK_BASE64=                 # REQUIRED — 32 raw bytes base64-encoded
CLG_KEK_VERSION=1

# ─── JWT (session) ───────────────────────────────────────────────────────────
# Generate: openssl rand -base64 64
CLG_JWT_SECRET=                 # REQUIRED — HS256 signing secret
CLG_JWT_TTL_SECONDS=28800       # 8h

# ─── Quota guard ─────────────────────────────────────────────────────────────
CLG_QUOTA_THRESHOLD_PCT=90
CLG_QUOTA_CACHE_TTL_SECONDS=30

# ─── Lifecycle defaults ──────────────────────────────────────────────────────
CLG_DEFAULT_CLEANUP_SECONDS=7200   # 2 hours
CLG_DEFAULT_FREEZE_SECONDS=86400   # 24 hours
CLG_DEPLOY_TIMEOUT_SECONDS=600     # max time for deploy saga
CLG_CHECK_TIMEOUT_SECONDS=300

# ─── OpenStack / КИ (Кибер Инфраструктура) ───────────────────────────────────
# Доступ к учебному кластеру КИ требует подключённого OpenVPN — см. docs/RUNBOOK.md.
# Web console (для людей):  https://edu.cyber-infrastructure.ru:8800/login/Hackhaton
# Keystone v3 API endpoint: уточнить у организаторов при выдаче креденшелов
# (стандартный порт 5000, но конкретный КИ может выставлять через 8800 с путём).
OPENSTACK_AUTH_URL=https://edu.cyber-infrastructure.ru:5000/v3
OPENSTACK_USERNAME=                 # выдают организаторы хакатона, персонально
OPENSTACK_PASSWORD=                 # выдают организаторы хакатона, REQUIRED
OPENSTACK_DOMAIN_NAME=Hackhaton     # имя КИ-домена для нашей команды
OPENSTACK_PROJECT_NAME=             # admin project, только для cluster-level reads
OPENSTACK_REGION=RegionOne
OPENSTACK_VERIFY_TLS=true
OPENSTACK_DEFAULT_FLAVOR=m1.small
OPENSTACK_PUBLIC_NETWORK_ID=        # uuid публичной сети для floating IP

# ─── LTI 1.3 ─────────────────────────────────────────────────────────────────
# JWKS of the Moodle instance for verifying launch JWTs.
LTI_JWKS_URL=https://moodle.example.com/mod/lti/certs.php
LTI_PLATFORM_ISSUER=https://moodle.example.com
LTI_AUDIENCE=cloud-lab-gateway
LTI_DEPLOYMENT_ID=

# Our keypair for signing AGS/NRPS requests back to Moodle (RSA, JWKS exposed at /lti/jwks).
LTI_TOOL_PRIVATE_KEY_PEM_PATH=/run/secrets/lti_tool_private_key.pem
LTI_TOOL_KID=clg-key-1

# ─── Moodle Web Services (legacy REST fallback) ──────────────────────────────
MOODLE_BASE_URL=https://moodle.example.com
MOODLE_WS_TOKEN=                     # encrypted in DB; this env is only for first bootstrap

# ─── Moodle Emulator (demo profile only) ─────────────────────────────────────
MOODLE_EMULATOR_PORT=9000
EMULATOR_LTI_KID=emu-key-1
